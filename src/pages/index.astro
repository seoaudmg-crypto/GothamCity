---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTAStrip from '../components/CTAStrip.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Gotham City Holding — Outsourced talent, one accountable entity"
  description="Gotham City Holding Pty Ltd sources and deploys specialised remote talent to support our clients across administration, offshore resourcing, and people operations."
>
  <Nav active="home" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__content">
        <div class="hero__eyebrow">
          <span class="hero__eyebrow-line" aria-hidden="true"></span>
          <span class="hero__eyebrow-text">OUTSOURCING &amp; OFFSHORE SOLUTIONS</span>
        </div>
        <h1 class="hero__title">
          <span class="hero__title-line1">Professional Services,</span>
          <span class="hero__title-line2">Delivered with Precision.</span>
        </h1>
        <p class="hero__sub">
          Gotham City Holding Pty Ltd sources and deploys specialised remote talent to support our
          clients across administration, offshore resourcing, and people operations.
        </p>
        <div class="hero__actions">
          <a href="/services" class="btn-primary">VIEW OUR SERVICES</a>
          <a href="/about" class="btn-outline">LEARN MORE</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="trust-strip">
    <ul class="trust-strip__list">
      <li class="trust-strip__item">
        <svg class="trust-strip__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>VETTED PROFESSIONALS</span>
      </li>
      <li class="trust-strip__item">
        <svg class="trust-strip__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <span>AUSTRALIA REGISTERED</span>
      </li>
      <li class="trust-strip__item">
        <svg class="trust-strip__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span>TRANSPARENT BILLING</span>
      </li>
      <li class="trust-strip__item">
        <svg class="trust-strip__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>TRUSTED &amp; COMPLIANT</span>
      </li>
    </ul>
  </div>

  <!-- ===== INTRO ===== -->
  <section class="intro">
    <div class="intro__inner">
      <!-- Left col: text -->
      <div class="intro__left">
        <p class="section-label">WHO WE ARE</p>
        <h2 class="intro__title">A Holding Company Built for Modern Delivery</h2>
        <p class="intro__body">
          Gotham City Holding Pty Ltd is an Australian-registered holding company that partners
          with legal and professional service firms to provide outsourced talent solutions. We
          source, vet, and deploy skilled specialists — ensuring our clients receive high-quality
          support seamlessly integrated into their workflows.
        </p>
        <p class="intro__body">
          Our billing structure is straightforward and transparent. When a resource works on your
          project, those hours are tracked and invoiced clearly — so you always know exactly what
          you're paying for.
        </p>
        <div class="intro__btn-wrap">
          <a href="/about" class="btn-outline-navy">ABOUT THE COMPANY</a>
        </div>
      </div>

      <!-- Right col: approach box -->
      <div class="intro__box">
        <p class="intro__box-label">OUR APPROACH</p>
        <h3 class="intro__box-title">
          Specialists placed where your business needs them most.
        </h3>
        <ul class="intro__box-list">
          <li class="intro__box-item">
            <span class="intro__box-dot" aria-hidden="true"></span>
            <span>Tailored talent matching for each engagement</span>
          </li>
          <li class="intro__box-item">
            <span class="intro__box-dot" aria-hidden="true"></span>
            <span>Fully transparent hourly billing</span>
          </li>
          <li class="intro__box-item">
            <span class="intro__box-dot" aria-hidden="true"></span>
            <span>Consistent quality across all disciplines</span>
          </li>
          <li class="intro__box-item">
            <span class="intro__box-dot" aria-hidden="true"></span>
            <span>Seamless integration with your existing team</span>
          </li>
          <li class="intro__box-item">
            <span class="intro__box-dot" aria-hidden="true"></span>
            <span>Australian-compliant engagement structure</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== HOW WE WORK ===== -->
  <section class="how">
    <div class="how__inner">
      <div class="how__head">
        <p class="section-label section-label--light">OUR PROCESS</p>
        <h2 class="how__title">How We Work</h2>
      </div>
      <ol class="how__steps">
        <li class="how__step">
          <span class="how__num" aria-hidden="true">01</span>
          <h3 class="how__step-title">Understanding Your Needs</h3>
          <p class="how__step-body">
            We start by understanding the scope of work, required skills, and timeline — so we can
            source the right fit.
          </p>
        </li>
        <li class="how__step">
          <span class="how__num" aria-hidden="true">02</span>
          <h3 class="how__step-title">Matching the Right Talent</h3>
          <p class="how__step-body">
            We identify and confirm the right professional from our network for your specific
            engagement.
          </p>
        </li>
        <li class="how__step">
          <span class="how__num" aria-hidden="true">03</span>
          <h3 class="how__step-title">Seamless Onboarding</h3>
          <p class="how__step-body">
            The resource integrates with your workflows and tools — no friction, no overhead for
            your team.
          </p>
        </li>
        <li class="how__step">
          <span class="how__num" aria-hidden="true">04</span>
          <h3 class="how__step-title">Transparent Billing</h3>
          <p class="how__step-body">
            Hours are tracked and invoiced clearly through Gotham City Holding — so your records
            stay clean.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="services">
    <div class="services__inner">
      <div class="services__head">
        <p class="section-label">WHAT WE OFFER</p>
        <h2 class="services__title">Our Services</h2>
        <p class="services__sub">
          We provide skilled professionals across virtual assistance, offshore resourcing, and HR —
          so your business has the right support at every stage.
        </p>
      </div>

      <div class="services__grid">
        <!-- Card 1: Virtual Assistant -->
        <div class="svc-card">
          <div class="svc-card__icon-box">
            <Icon name="headset" size={28} />
          </div>
          <h3 class="svc-card__title">Virtual Assistant</h3>
          <p class="svc-card__desc">Reliable remote support for your day-to-day operations — inbox and calendar management, scheduling, data entry, research, and the administrative tasks that keep your business moving.</p>
          <a href="/services/virtual-assistant" class="svc-card__link">
            Learn more
            <Icon name="arrow-right" size={14} />
          </a>
        </div>

        <!-- Card 2: Offshore Resourcing -->
        <div class="svc-card">
          <div class="svc-card__icon-box">
            <Icon name="globe" size={28} />
          </div>
          <h3 class="svc-card__title">Offshore Resourcing</h3>
          <p class="svc-card__desc">Allocation and management of skilled offshore professionals — we match the right talent to your needs and oversee delivery, so you gain capacity without the management burden.</p>
          <a href="/services" class="svc-card__link">
            Learn more
            <Icon name="arrow-right" size={14} />
          </a>
        </div>

        <!-- Card 3: HR Services -->
        <div class="svc-card">
          <div class="svc-card__icon-box">
            <Icon name="users-round" size={28} />
          </div>
          <h3 class="svc-card__title">HR Services</h3>
          <p class="svc-card__desc">Recruitment, onboarding, payroll coordination, and compliance — we handle the people function so your team stays lean and focused.</p>
          <a href="/services/offshore-hr" class="svc-card__link">
            Learn more
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      </div>

      <div class="services__cta-wrap">
        <a href="/services" class="btn-explore">
          Explore All Services
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <CTAStrip />

  <!-- ===== FOOTER ===== -->
  <Footer />
</BaseLayout>

<style>
  /* ─── Shared section label ─── */
  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin: 0;
  }
  .section-label--light {
    color: var(--color-accent);
  }

  /* ─── HERO ─── */
  .hero {
    background: var(--color-primary);
    width: 100%;
    min-height: calc(85.5vh); /* fill viewport below the 72px sticky nav */
    display: flex;
    align-items: center; /* vertically center content like the design (hero is 680px, justify center) */
  }
  .hero__inner {
    width: 100%;
    max-width: calc(var(--container-max) + 2 * var(--section-x));
    margin: 0 auto;
    padding: 80px var(--section-x);
  }
  .hero__content {
    max-width: 720px;
  }
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 0;
  }
  .hero__eyebrow-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }
  .hero__eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    text-transform: uppercase;
  }
  .hero__title {
    display: flex;
    flex-direction: column;
    margin: var(--space-6) 0 0;
    gap: 0;
  }
  .hero__title-line1 {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text-light);
  }
  .hero__title-line2 {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.1;
    color: var(--color-accent);
  }
  .hero__sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: var(--space-6) 0 0;
    max-width: 540px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-10);
  }

  /* ─── Shared buttons ─── */
  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: var(--color-accent-dark);
  }
  .btn-outline {
    display: inline-block;
    background: transparent;
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    border: 2px solid rgba(255, 255, 255, 0.5);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--color-text-light);
    color: var(--color-text-light);
  }
  .btn-outline-navy {
    display: inline-block;
    background: transparent;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    border: 2px solid var(--color-primary);
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline-navy:hover {
    background: var(--color-primary);
    color: var(--color-text-light);
  }

  /* ─── TRUST STRIP ─── */
  .trust-strip {
    background: var(--color-accent);
    width: 100%;
  }
  .trust-strip__list {
    list-style: none;
    margin: 0;
    padding: 20px var(--section-x);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    max-width: 100%;
  }
  .trust-strip__item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    color: var(--color-primary);
    text-transform: uppercase;
  }
  .trust-strip__icon {
    flex-shrink: 0;
    color: var(--color-primary);
  }

  /* ─── INTRO ─── */
  .intro {
    background: var(--color-bg);
    width: 100%;
  }
  .intro__inner {
    max-width: calc(var(--container-max) + 2 * var(--section-x));
    margin: 0 auto;
    padding: 96px var(--section-x);
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 64px;
    align-items: center; /* vertically center the two columns, matching the design */
  }
  .intro__left {
    display: flex;
    flex-direction: column;
  }
  .intro__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.375rem);
    font-weight: 700;
    color: var(--color-primary);
    margin: var(--space-3) 0 0;
    line-height: 1.2;
  }
  .intro__body {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: var(--space-6) 0 0;
  }
  .intro__btn-wrap {
    margin-top: var(--space-8);
  }
  /* Right: dark box */
  .intro__box {
    background: var(--color-primary);
    border-radius: 20px;
    padding: 48px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .intro__box-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }
  .intro__box-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin: var(--space-4) 0 0;
    line-height: 1.4;
  }
  .intro__box-list {
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .intro__box-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.4;
  }
  .intro__box-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-top: 5px;
  }

  /* ─── HOW WE WORK ─── */
  .how {
    background: var(--color-primary);
    width: 100%;
  }
  .how__inner {
    max-width: calc(var(--container-max) + 2 * var(--section-x));
    margin: 0 auto;
    padding: 96px var(--section-x);
  }
  .how__head {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: center;
  }
  .how__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text-light);
    margin: var(--space-3) 0 0;
  }
  .how__steps {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .how__step {
    display: flex;
    flex-direction: column;
  }
  .how__num {
    font-family: 'Courier New', Courier, monospace;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: rgba(201, 168, 76, 0.2);
    display: block;
  }
  .how__step-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin: var(--space-4) 0 0;
    line-height: 1.3;
  }
  .how__step-body {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin: var(--space-3) 0 0;
  }

  /* ─── SERVICES ─── */
  .services {
    background: var(--color-bg-alt);
    width: 100%;
  }
  .services__inner {
    max-width: calc(var(--container-max) + 2 * var(--section-x));
    margin: 0 auto;
    padding: 96px var(--section-x);
  }
  .services__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .services__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-primary);
    margin: var(--space-3) 0 0;
  }
  .services__sub {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: var(--space-4) 0 0;
    max-width: 560px;
  }
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  /* ─── Service Cards (Home 3-card thematic overview) ─── */
  .svc-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .svc-card__icon-box {
    width: 56px;
    height: 56px;
    background: rgba(var(--color-primary-rgb), 0.06);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .svc-card__title {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: var(--space-4) 0 0;
    line-height: 1.3;
  }
  .svc-card__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: var(--space-3) 0 0;
    flex: 1;
  }
  .svc-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-5);
    color: var(--color-accent-dark);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    text-decoration: none;
    transition: gap 0.2s;
  }
  .svc-card__link:hover {
    gap: 10px;
  }
  .services__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }
  .btn-explore {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.0625em;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    transition: background 0.2s, color 0.2s;
  }
  .btn-explore:hover {
    background: var(--color-primary);
    color: var(--color-text-light);
  }
  .btn-explore svg {
    transition: transform 0.2s;
  }
  .btn-explore:hover svg {
    transform: translateX(4px);
  }

  /* ─── RESPONSIVE ─── */

  /* Tablet ≤ 1024px */
  @media (max-width: 1024px) {
    .hero {
      min-height: auto;
    }
    .intro__inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .intro__box {
      width: 100%;
    }
    .how__steps {
      grid-template-columns: repeat(2, 1fr);
    }
    .trust-strip__list {
      justify-content: flex-start;
      gap: var(--space-6);
    }
  }

  /* Services grid collapses at ≤ 900px */
  @media (max-width: 900px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Mobile < 640px */
  @media (max-width: 639px) {
    .hero__inner {
      padding: 64px var(--section-x);
    }
    .hero__title-line1,
    .hero__title-line2 {
      font-size: 2rem;
    }
    .hero__sub {
      font-size: 1rem;
    }
    .hero__actions {
