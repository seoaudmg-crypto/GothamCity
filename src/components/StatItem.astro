---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="stat-item">
  <span class="stat-item__value">{value}</span>
  <span class="stat-item__label">{label}</span>
</div>

<style>
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .stat-item__value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-item__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
  }
</style>
