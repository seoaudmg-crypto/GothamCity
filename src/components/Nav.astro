---
import { services } from '../data/services.ts';
import { site } from '../data/site.ts';
import Icon from './Icon.astro';

interface Props {
  active?: 'home' | 'services' | 'about' | 'contact';
}

const { active } = Astro.props;

// Category icon map
const catIcon: Record<string, string> = {
  'virtual-assistant': 'headset',
  'resource-allocation': 'users-round',
  'offshore-hr': 'user-check',
  'it-services': 'code',
  'it-resource-allocation': 'server',
  'digital-marketing': 'megaphone',
  'customer-support': 'headphones',
  'back-office': 'database',
  'rpo': 'user-search',
};
---

<header class="site-nav" role="banner">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label={site.shortName + ' - home'}>
      <img src="/logo.png" alt={site.shortName} class="logo-img" />
    </a>

    <!-- Desktop nav links -->
    <nav class="desktop-links" aria-label="Primary navigation">
      <a href="/" class:list={['nav-link', { 'nav-link--active': active === 'home' }]}>Home</a>

      <!-- Services with mega-menu -->
      <div class="services-wrap">
        <a
          href="/services"
          class:list={['nav-link', { 'nav-link--active': active === 'services' }]}
          aria-haspopup="true"
        >
          Services
          <Icon name="chevron-down" size={14} />
        </a>

        <div class="mega-menu" role="region" aria-label="Services categories">
          <div class="mega-panel">
            <!-- LEFT: category list -->
            <div class="mega-cats" role="list">
              {services.map((svc, i) => (
                <a
                  href={`/services/${svc.slug}`}
                  class:list={['mega-cat-row', { 'is-active': i === 0 }]}
                  data-cat={svc.slug}
                  role="listitem"
                >
                  <span class="mega-cat-icon">
                    <Icon name={catIcon[svc.slug] ?? 'layers'} size={18} />
                  </span>
                  <span class="mega-cat-name">{svc.name}</span>
                  <span class="mega-cat-chevron">
                    <Icon name="chevron-right" size={16} />
                  </span>
                </a>
              ))}
            </div>

            <!-- RIGHT: detail blocks (one per category) -->
            <div class="mega-detail-pane">
              {services.map((svc, i) => {
                const half = Math.ceil(svc.included.length / 2);
                const col1 = svc.included.slice(0, half);
                const col2 = svc.included.slice(half);
                return (
                  <div
                    class:list={['mega-detail', { 'is-active': i === 0 }]}
                    data-detail={svc.slug}
                  >
                    <p class="mega-detail__title">{svc.name}</p>
                    <p class="mega-detail__desc">{svc.tagline}</p>
                    <div class="mega-detail__checklist">
                      <ul class="mega-checklist-col" role="list">
                        {col1.map((item) => (
                          <li class="mega-check-item">
                            <span class="mega-check-icon"><Icon name="check" size={14} /></span>
                            <span class="mega-check-text">{item}</span>
                          </li>
                        ))}
                      </ul>
                      {col2.length > 0 && (
                        <ul class="mega-checklist-col" role="list">
                          {col2.map((item) => (
                            <li class="mega-check-item">
                              <span class="mega-check-icon"><Icon name="check" size={14} /></span>
                              <span class="mega-check-text">{item}</span>
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                    <a href={`/services/${svc.slug}`} class="mega-detail__cta">
                      <span>View all {svc.name}</span>
                      <Icon name="arrow-right" size={15} />
                    </a>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <a href="/about" class:list={['nav-link', { 'nav-link--active': active === 'about' }]}>About</a>
      <a href="/contact" class:list={['nav-link', { 'nav-link--active': active === 'contact' }]}>Contact</a>
    </nav>

    <!-- CTA -->
    <a href="/contact" class="nav-cta desktop-cta">GET IN TOUCH</a>

    <!-- Mobile hamburger -->
    <button
      class="hamburger"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-panel"
    >
      <span class="hamburger__open" aria-hidden="true"><Icon name="menu" size={24} /></span>
      <span class="hamburger__close" aria-hidden="true"><Icon name="x" size={24} /></span>
    </button>
  </div>

  <!-- Mobile panel -->
  <div id="mobile-panel" class="mobile-panel" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <a href="/" class:list={['mobile-link', { 'mobile-link--active': active === 'home' }]}>Home</a>
      <a href="/services" class:list={['mobile-link', { 'mobile-link--active': active === 'services' }]}>Services</a>

      <div class="mobile-services">
        <p class="mobile-services__label">All Services</p>
        <ul class="mobile-services__list" role="list">
          {services.map((svc) => (
            <li>
              <a href={`/services/${svc.slug}`} class="mobile-service-item">
                <Icon name="arrow-right" size={13} />
                {svc.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <a href="/about" class:list={['mobile-link', { 'mobile-link--active': active === 'about' }]}>About</a>
      <a href="/contact" class:list={['mobile-link', { 'mobile-link--active': active === 'contact' }]}>Contact</a>

      <a href="/contact" class="nav-cta mobile-cta">GET IN TOUCH</a>
    </nav>
  </div>
</header>

<style>
  /* â"€â"€â"€ Base header â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-primary);
    width: 100%;
  }

  .nav-inner {
    width:100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    padding: 0 48px;
    gap: 32px;
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 52px;
    width: auto;
    object-fit: contain;
  }

  /* â"€â"€â"€ Desktop nav links â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .desktop-links {
    display: flex;
    align-items: center;
    gap: 36px;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-text-light);
  }

  /* â"€â"€â"€ Services mega-menu wrapper â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .services-wrap {
    align-self: stretch;
    display: flex;
    align-items: center;
    position: relative;
  }

  .services-wrap .nav-link svg {
    transition: transform 0.2s ease;
  }

  .services-wrap:hover .nav-link svg,
  .services-wrap:focus-within .nav-link svg,
  .services-wrap.mega-open .nav-link svg {
    transform: rotate(180deg);
  }

  /* Outer hoverable shell — fixed, centered, includes transparent 12px bridge */
  .mega-menu {
    position: fixed;
    top: 72px;
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    padding-top: 12px; /* transparent hover bridge */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
    z-index: 99;
  }

  .services-wrap:hover .mega-menu,
  .services-wrap:focus-within .mega-menu,
  .services-wrap.mega-open .mega-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Inner visible card */
  .mega-panel {
    width: 820px;
    max-width: calc(100vw - 40px);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 48px rgba(var(--color-primary-rgb), 0.2);
    overflow: hidden;
    display: flex;
  }

  /* LEFT pane — category list */
  .mega-cats {
    width: 340px;
    flex-shrink: 0;
    background: var(--color-bg-alt);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mega-cat-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .mega-cat-icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    transition: color 0.12s ease;
  }

  .mega-cat-name {
    flex: 1;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.12s ease, font-weight 0.12s ease;
  }

  .mega-cat-chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    transition: color 0.12s ease;
  }

  /* Active (hovered or default first) state for left row */
  .mega-cat-row.is-active,
  .mega-cat-row:hover,
  .mega-cat-row:focus-visible {
    background: var(--color-surface);
  }

  .mega-cat-row.is-active .mega-cat-icon,
  .mega-cat-row:hover .mega-cat-icon,
  .mega-cat-row:focus-visible .mega-cat-icon {
    color: var(--color-primary);
  }

  .mega-cat-row.is-active .mega-cat-name,
  .mega-cat-row:hover .mega-cat-name,
  .mega-cat-row:focus-visible .mega-cat-name {
    color: var(--color-primary);
    font-weight: 600;
  }

  .mega-cat-row.is-active .mega-cat-chevron,
  .mega-cat-row:hover .mega-cat-chevron,
  .mega-cat-row:focus-visible .mega-cat-chevron {
    color: var(--color-accent-dark);
  }

  /* RIGHT pane — detail */
  .mega-detail-pane {
    flex: 1;
    min-width: 0;
    background: var(--color-surface);
    padding: 32px;
    position: relative;
  }

  .mega-detail {
    display: none;
    flex-direction: column;
    gap: 20px;
  }

  .mega-detail.is-active {
    display: flex;
  }

  .mega-detail__title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .mega-detail__desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .mega-detail__checklist {
    display: flex;
    gap: 20px;
  }

  .mega-checklist-col {
    flex: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  .mega-check-item {
    display: flex;
    align-items: flex-start;
    gap: 9px;
  }

  .mega-check-icon {
    flex-shrink: 0;
    color: var(--color-accent-dark);
    display: flex;
    align-items: center;
    margin-top: 1px;
  }

  .mega-check-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-primary);
    line-height: 1.45;
  }

  .mega-detail__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--color-accent-dark);
    text-decoration: none;
    padding-top: 8px;
    transition: opacity 0.15s ease;
  }

  .mega-detail__cta:hover {
    opacity: 0.8;
  }

  /* â"€â"€â"€ CTA button â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .nav-cta:hover {
    background: var(--color-accent-light);
  }

  .nav-cta:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* â"€â"€â"€ Hamburger button â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text-light);
    padding: 4px;
    line-height: 0;
  }

  .hamburger__close {
    display: none;
  }

  .hamburger[aria-expanded="true"] .hamburger__open {
    display: none;
  }

  .hamburger[aria-expanded="true"] .hamburger__close {
    display: flex;
  }

  /* â"€â"€â"€ Mobile panel â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  .mobile-panel {
    display: none;
    flex-direction: column;
    background: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0 24px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .mobile-panel.is-open {
    max-height: 80vh;
    overflow-y: auto;
    padding: 16px 24px 24px;
  }

  .mobile-link {
    display: block;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: color 0.15s ease;
  }

  .mobile-link:hover,
  .mobile-link--active {
    color: var(--color-text-light);
  }

  .mobile-services {
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mobile-services__label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0 0 8px;
  }

  .mobile-services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-service-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    padding: 7px 0;
    transition: color 0.15s ease;
  }

  .mobile-service-item:hover {
    color: var(--color-text-light);
  }

  .mobile-service-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .mobile-cta {
    display: inline-flex;
    margin-top: 20px;
    align-self: flex-start;
  }

  /* â"€â"€â"€ Responsive â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ */
  @media (max-width: 767px) {
    .nav-inner {
      padding: 0 24px;
    }

    .desktop-links {
      display: none;
    }

    .desktop-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-panel {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .nav-inner {
      padding: 0 16px;
    }

    .logo-img {
      height: 44px;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.hamburger');
  const panel = document.querySelector<HTMLElement>('#mobile-panel');

  if (btn && panel) {
    function openNav() {
      btn!.setAttribute('aria-expanded', 'true');
      panel!.setAttribute('aria-hidden', 'false');
      panel!.classList.add('is-open');
    }

    function closeNav() {
      btn!.setAttribute('aria-expanded', 'false');
      panel!.setAttribute('aria-hidden', 'true');
      panel!.classList.remove('is-open');
    }

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      if (isOpen) closeNav();
      else openNav();
    });

    // Close on any link click inside the panel
    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeNav);
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        closeNav();
        btn.focus();
      }
    });
  }

  // ── Mega-menu: left-row hover switches right detail ──────────────
  const catRows = document.querySelectorAll<HTMLElement>('.mega-cat-row');
  const detailBlocks = document.querySelectorAll<HTMLElement>('.mega-detail');

  function activateCat(slug: string) {
    catRows.forEach((row) => {
      row.classList.toggle('is-active', row.dataset.cat === slug);
    });
    detailBlocks.forEach((block) => {
      block.classList.toggle('is-active', block.dataset.detail === slug);
    });
  }

  catRows.forEach((row) => {
    row.addEventListener('mouseenter', () => {
      const slug = row.dataset.cat;
      if (slug) activateCat(slug);
    });
    row.addEventListener('focus', () => {
      const slug = row.dataset.cat;
      if (slug) activateCat(slug);
    });
  });

  // ── Mega-menu: keep open across the diagonal hover gap (grace period) ──
  const servicesWrap = document.querySelector<HTMLElement>('.services-wrap');
  const megaMenu = servicesWrap?.querySelector<HTMLElement>('.mega-menu');
  if (servicesWrap && megaMenu) {
    let megaTimer: ReturnType<typeof setTimeout> | undefined;
    const openMega = () => {
      if (megaTimer) clearTimeout(megaTimer);
      servicesWrap.classList.add('mega-open');
    };
    const closeMega = () => {
      if (megaTimer) clearTimeout(megaTimer);
      megaTimer = setTimeout(() => servicesWrap.classList.remove('mega-open'), 250);
    };
    // Open when entering the trigger or the panel; close (after a grace delay)
    // when leaving either — the delay lets the cursor cross the gap between
    // the Services link and the centered panel without the menu vanishing.
    servicesWrap.addEventListener('mouseenter', openMega);
    servicesWrap.addEventListener('mouseleave', closeMega);
    megaMenu.addEventListener('mouseenter', openMega);
    megaMenu.addEventListener('mouseleave', closeMega);
  }
</script>
