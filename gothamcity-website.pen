                {
                  "type": "text",
                  "id": "YhQ6L",
                  "name": "Para",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Gotham City Holding Pty Ltd is an Australian-registered company that helps businesses access skilled professionals without the overhead of building large in-house teams. From virtual assistants to software engineers, we provide the people and the structure to extend your capacity on demand.",
                  "lineHeight": 1.7,
                  "fontFamily": "$font-body",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "AxiaZ",
                  "name": "Para",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We operate as a single, accountable entity. The professionals who work on your behalf are engaged, managed, and billed through Gotham City Holding — so you get clear ownership, consistent quality, and straightforward, transparent invoicing.",
                  "lineHeight": 1.7,
                  "fontFamily": "$font-body",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "j9C4Zd",
                  "name": "Para",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Our model is simple: the right talent, matched to your needs, delivered reliably and billed clearly. Whether you need ongoing support or project-based capacity, we make outsourcing feel like a natural extension of your own team.",
                  "lineHeight": 1.7,
                  "fontFamily": "$font-body",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
